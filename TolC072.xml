  <text xml:lang="ta" type="edition">
    <body>
        <lg xml:id="TolC072">
          <l>kāppi ṉoppi ṉūrtiyi ṉiḻaiyi</l>
	<l>ṉōppiṟ pukaḻiṟ paḻiyi ṉeṉṟā</l>
	<l>peṟali ṉiḻaviṟ kātaliṉ vekuḷiyiṟ</l>
	<l>ceṟali ṉuvattaliṟ kaṟpi ṉeṉṟā</l>
	<l>vaṟuttaliṟ kuṟaittaliṟ ṟokuttaliṟ pirittali</l>
	<l>ṉiṟuttali ṉaḷavi ṉeṇṇi ṉeṉṟā</l>
	<l>vākkaliṟ cārtaliṟ celaviṟ kaṉṟali</l>
	<l>ṉōkkali ṉañcaliṟ citaippi ṉeṉṟā</l>
	<l>vaṉṉa piṟavu mammutaṟ poruḷa</l>
	<l>veṉṉa kiḷaviyu mataṉpāla veṉmaṉār.</l>
        </lg>
    </body>
  </text>
