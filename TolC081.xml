  <text xml:lang="ta" type="edition">
    <body>
        <lg xml:id="TolC081">
          <l>ēḻā kuvatē,</l>
	<l>kaṇṇeṉap peyariya vēṟṟumaik kiḷavi</l>
	<l>viṉaicey yiṭatti ṉilattiṟ kālatti</l>
	<l>ṉaṉaivakaik kuṟippiṟ ṟōṉṟu matuvē.</l>
        </lg>
    </body>
  </text>
