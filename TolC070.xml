  <text xml:lang="ta" type="edition">
    <body>
        <lg xml:id="TolC070">
          <l>peyarnilaik kiḷavi kālan tōṉṟā</l>
          <l>toḻilnilai yoṭṭum oṉṟalaṅ kaṭaiyē.</l>
        </lg>
