  <text xml:lang="ta" type="edition">
    <body>
        <lg xml:id="TolC069">
          <l>kūṟiya muṟaiyi ṉurupunilai tiriyā</l>
          <l>tīṟupeyark kāku miyaṟkaiya veṉpa.</l>
        </lg>
    </body>
  </text>
