  <text xml:lang="ta" type="edition">
    <body>
        <lg xml:id="TolC080">
          <l>iyaṟkaiyiṉuṭaimaiyiṉ muṟaimaiyiṟkiḻamaiyiṟ</l>
	<l>ceyaṟkaiyiṉ mutumaiyiṉ viṉaiyi ṉeṉṟā</l>
	<l>karuviyiṟ ṟuṇaiyiṟ kalattiṉ mutali</l> 
	<l>ṉoruvaḻi yuṟuppiṟ kuḻuvi ṉeṉṟā</l>
	<l>terintumoḻicceytiyi ṉilaiyiṉvāḻcciyiṟ</l>
	<l>ṟirintuvēṟu paṭūum piṟavu maṉṉa</l>
	<l>kūṟiya maruṅkiṟ ṟōṉṟuṅ kiḷavi</l>
	<l>yāṟaṉ pāla veṉmaṉār pulavar.</l>
        </lg>
    </body>
  </text>
  <text xml:lang="ta" type="edition">
    <body>
        <head>Iḷampūraṇar</head>
        <p xml:lang="en">ed. <persName xml:lang="ta">Namaccivāya Mutaliyār</persName> 1931, <ref target="https://archive.org/details/dli.jZY9lup2kZl6TuXGlZQdjZMelJhy.TVA_BOK_0007521/page/156/mode/1up">156</ref>.</p>
      <p>
      </p>
