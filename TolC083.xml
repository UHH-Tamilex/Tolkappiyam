  <text xml:lang="ta" type="edition">
    <body>
        <lg xml:id="TolC083">
          <l>vēṟṟumaip poruḷai virikkuṅ kālai</l>
	<l>yīṟṟuniṉ ṟiyalun tokaivayiṟ pirintu</l>
	<l>pallā ṟākap poruḷpuṇarn ticaikku</l>
	<l>mellāc collu muriya veṉpa.</l>
        </lg>
    </body>
  </text>
  <text xml:lang="ta" type="edition">
    <body>
