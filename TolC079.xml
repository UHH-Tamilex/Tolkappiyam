  <text xml:lang="ta" type="edition">
    <body>
        <lg xml:id="TolC079">
          <l>āṟā kuvatē,</l>
	<l>atuveṉap peyariya vēṟṟumaik kiḷavi</l>
	<l>taṉṉiṉum piṟitiṉu mitaṉa tituveṉu</l>
	<l>maṉṉa kiḷavik kiḻamait tatuvē.</l>
        </lg>
    </body>
  </text>
  <text xml:lang="ta" type="edition">
