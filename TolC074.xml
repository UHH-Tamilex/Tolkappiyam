  <text xml:lang="ta" type="edition">
    <body>
        <lg xml:id="TolC074">
          <l>ataṉi ṉiyaṟa lataṟṟaku kiḷavi</l>
<l>yataṉviṉaip paṭuta lataṉi ṉāta</l>
<l>lataṉiṟ kōṭa lataṉoṭu mayaṅka</l>
<l>lataṉō ṭiyainta voruviṉaik kiḷavi</l>
<l>yataṉō ṭiyainta vēṟuviṉaik kiḷavi</l>
<l>yataṉō ṭiyainta voppa loppurai</l>
<l>yiṉṉā ṉētu vīṅkeṉa varūu</l>
<l>maṉṉa piṟavu mataṉpāla veṉmaṉār.</l>
        </lg>
    </body>
