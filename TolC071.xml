  <text xml:lang="ta" type="edition">
    <body>
        <lg xml:id="TolC071">
          <l>iraṇṭā kuvatē,</l>
	<l>aiyeṉap peyariya vēṟṟumaik kiḷavi</l>
	<l>yevvaḻi variṉum viṉaiyē viṉaikkuṟip</l>
	<l>pavviru mutaliṟ ṟōṉṟu matuvē.</l>
        </lg>
    </body>
  </text>
  <text xml:lang="ta" type="edition">
